# Overrides sourced by /opt/deploy/infra/scripts/project-deploy.sh and
# project-backup.sh on the Hetzner box (plain shell KEY=VALUE lines).

# Deploy: build/migrate/restart use the production compose file, not the dev one.
BRANCH=main
COMPOSE_FILE=/srv/fitness-store/docker-compose.production.yml
WEB_SERVICE=web

# Sandbox file ownership to the per-app system user created by `repo create`.
# (repo name "fitness-store" -> system user "fitness_store".)
APP_USER=fitness_store
APP_GROUP=fitness_store

# Backups: matches the `postgres` service name in the production compose.
DB_SERVICE_NAME=postgres
RETENTION_DAYS=14
# Off-site backup sync — point at an rclone remote configured on the box
# (e.g. an S3 bucket) to also mirror on-demand `deploy backup run` dumps.
# The nightly wrapper (scripts/backup.sh) exports this itself, so it can stay
# unset here unless you want on-demand runs to mirror off-site too:
# RCLONE_REMOTE=hetzner-db-backups:lance-hetzner-db-backups/fitness-store
