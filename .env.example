# Environment variables for Mastering Fitness.
#
# LOCAL DEV: copy to `.env`, set DJANGO_SETTINGS_MODULE=config.settings.local,
#   ENVIRONMENT=DEVELOPMENT, DEBUG=1, and use the SQL_* vars (the dev
#   docker-compose runs Postgres on :5434 / Redis on :6334). Most keys below
#   have safe dev defaults and may be left blank.
#
# PRODUCTION (Hetzner via the `deploy` CLI): `deploy repo create` auto-fills
#   SECRET_KEY, DB_NAME, DB_USER, DB_PASSWORD and ALLOWED_HOSTS in the
#   server-side /srv/fitness-store/.env. The remaining values are copied from
#   the old Heroku config. docker-compose.production.yml derives SQL_*,
#   DJANGO_ALLOWED_HOSTS, CSRF_TRUSTED_ORIGINS, REDIS_URL and the settings
#   module from these via its `environment:` block, so do NOT set DATABASE_URL.

# --- Django core ---------------------------------------------------------
# Auto-generated by `deploy repo create` in production. Leave blank locally
# to fall back to the insecure dev default.
SECRET_KEY=
# Production module is forced by the container; set to config.settings.local here for dev.
DJANGO_SETTINGS_MODULE=config.settings.local
ENVIRONMENT=DEVELOPMENT
DEBUG=1

# --- Database ------------------------------------------------------------
# Production: `deploy repo create` fills these; the compose file maps them to
# SQL_* (app) and POSTGRES_* (db service).
DB_NAME=
DB_USER=
DB_PASSWORD=
# Local dev reads these directly (config.settings.local):
SQL_DATABASE=
SQL_USER=
SQL_PASSWORD=
SQL_HOST=
SQL_PORT=

# --- Hosts / domain ------------------------------------------------------
# Production: `deploy repo create` sets ALLOWED_HOSTS to the domain; the compose
# file expands it into DJANGO_ALLOWED_HOSTS (apex + www) and CSRF_TRUSTED_ORIGINS.
ALLOWED_HOSTS=
DJANGO_ALLOWED_HOSTS=
DOMAIN_URL=
CORS_ALLOWED_ORIGINS=

# --- Stripe (payments) ---------------------------------------------------
# https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_ENDPOINT_SECRET=

# --- Facebook login ------------------------------------------------------
# https://developers.facebook.com/apps/
FB_APP_ID=
FB_SECRET_KEY=

# --- Google login --------------------------------------------------------
# https://console.developers.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AWS S3 (media storage) ----------------------------------------------
# Optional locally (defaults to dummy keys); required in production.
AWS_ACCESS_KEY_ID=local-access-key
AWS_SECRET_ACCESS_KEY=local-secret-key

# --- AWS SES (transactional email; production only) ----------------------
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION_NAME=us-east-2
AWS_SES_REGION_ENDPOINT=email.us-east-2.amazonaws.com
AWS_SES_CONFIGURATION_SET=Tracking

# --- Google reCAPTCHA (contact form) -------------------------------------
# https://www.google.com/recaptcha/admin/create
G_RECAPTCHA_SITE_KEY=
G_RECAPTCHA_SECRET_KEY=
G_RECAPTCHA_ENDPOINT=

# --- Google Generative AI (challenge admin) ------------------------------
GOOGLE_API_KEY=

# --- Analytics / error monitoring ----------------------------------------
GOOGLE_ANALYTICS_GTAG_PROPERTY_ID=
SENTRY_DSN=

# --- Scout APM ------------------------------------------------------------
# Scout APM was removed (no `scout-apm` dependency). To bring it back, re-add
# the dependency and the opt-in block in app/config/settings/production.py;
# only then do SCOUT_MONITOR / SCOUT_KEY have any effect.
